# ==========================================
# Version Control
# ==========================================
# Git
.git/
*.orig
*.patch
*.diff

# ==========================================
# IMPORTANT NOTES
# ==========================================
# 1. If you accidentally commit .env file:
#    - Immediately regenerate your API key
#    - Remove from Git history: 
#      git filter-branch --force --index-filter \
#      "git rm --cached --ignore-unmatch .env" \
#      --prune-empty --tag-name-filter cat -- --all
#
# 2. To check what will be committed:
#    git status
#    git add -n .  (dry run)
#
# 3. Never share:
#    - .env files
#    - API keys
#    - User data files
#    - Database files
